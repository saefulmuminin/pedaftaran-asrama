rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: hanya bisa baca/tulis data sendiri, admin bisa semua
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Pendaftaran:
    //   - CREATE publik: form pendaftaran tanpa akun (userId == null, status submitted).
    //     Validasi field wajib + status awal harus 'submitted'.
    //   - CREATE owner: kalau user sudah login, harus sesuai userId-nya.
    //   - READ: owner (kalau userId sudah ke-link) atau admin.
    //   - UPDATE: owner saat status draft/ditolak, atau admin.
    //   - DELETE: hanya admin.
    match /pendaftaran/{docId} {
      allow read: if isAdmin() || (
        request.auth != null && resource.data.userId == request.auth.uid
      );

      allow create: if
        // Submission publik tanpa akun
        (
          request.resource.data.userId == null
          && request.resource.data.status == 'submitted'
          && request.resource.data.namaLengkap is string
          && request.resource.data.email is string
          && request.resource.data.nik is string
        )
        // ATAU submission dari user yang sudah login
        || (request.auth != null && request.resource.data.userId == request.auth.uid);

      allow update: if isAdmin() || (
        request.auth != null
        && resource.data.userId == request.auth.uid
        && resource.data.status in ['draft', 'ditolak']
      );

      allow delete: if isAdmin();
    }

    // Kamar: publik bisa baca (form pendaftaran cek kapasitas), hanya admin tulis
    match /kamar/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Penghuni: semua user login bisa baca, hanya admin bisa tulis
    match /penghuni/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Tata Tertib: publik bisa baca (tanpa login), hanya admin bisa tulis.
    match /tataTertib/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Pengaturan sistem (mis. metode pembayaran aktif): semua user login bisa baca,
    // hanya admin bisa tulis.
    match /pengaturan/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Buku Tamu: semua user login bisa baca & lapor; hanya admin yang bisa hapus.
    match /tamu/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.dilaporOlehUid == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Kegiatan: semua user login bisa baca. Hanya admin yang bisa create/update/delete.
    match /kegiatan/{docId} {
      allow read: if request.auth != null;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Laporan & Keluhan:
    //   - READ: pelapor (sendiri) atau admin.
    //   - CREATE: user login membuat laporan untuk dirinya sendiri (status awal 'baru').
    //   - UPDATE: hanya admin (untuk tanggapan & ubah status).
    //   - DELETE: admin selalu boleh; pelapor boleh kalau status masih 'baru'.
    match /laporan/{docId} {
      allow read: if isAdmin() || (
        request.auth != null && resource.data.pelaporUid == request.auth.uid
      );
      allow create: if request.auth != null
        && request.resource.data.pelaporUid == request.auth.uid
        && request.resource.data.status == 'baru';
      allow update: if isAdmin();
      allow delete: if isAdmin() || (
        request.auth != null
        && resource.data.pelaporUid == request.auth.uid
        && resource.data.status == 'baru'
      );
    }

    // Tagihan:
    //   - READ: semua user login bisa baca semua tagihan (transparansi pembayaran).
    //   - CREATE: hanya admin (generate massal / custom).
    //   - UPDATE: admin atau pemilik tagihan (untuk verify-payment flow).
    //   - DELETE: hanya admin.
    match /tagihan/{docId} {
      allow read: if request.auth != null;
      allow create: if isAdmin();
      allow update: if isAdmin() || (
        request.auth != null && resource.data.userId == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    // Notifikasi: user hanya baca milik sendiri, admin bisa buat
    match /notifikasi/{docId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAdmin();
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
